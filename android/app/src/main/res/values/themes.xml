<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Use NoActionBar for custom header -->
    <style name="Theme.WebAppAndroid" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_dark_blue</item>
        <item name="colorPrimaryVariant">@color/brand_mid_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_button_dark</item>
        <item name="colorSecondaryVariant">@color/brand_button_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/brand_dark_blue</item>
    </style>
</resources>
